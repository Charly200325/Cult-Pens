{%- comment -%}
  Parameters:
  - show_collection_listing_link {Boolean} - Show the collections list link (optional, default is false).
  - show_next_prev {Boolean} - Show prev/next product links on product pages (optional, default is false).
  - show_rss_link {Boolean} - Show an rss link on blog pages. (optional, default is false).
  - divider {String} - Markup to use for the divider (optional).
  - prev_icon {String} - Markup to use for the previous product button (optional).
  - next_icon {String} - Markup to use for the next product button (optional).

  Usage:
  {%- capture divider -%}
    <span class="icon">{% render 'icon-chevron-right' %}</span>
  {%- endcapture -%}
  {% render 'breadcrumbs', divider: divider, show_next_prev: true %}
{%- endcomment -%}

{%- liquid
  assign show_crumbs = true
  assign show_structured_data = true
  assign show_collection_listing_link = false
  assign breadcrumbs_title = 'general.breadcrumbs.title' | t
  assign home_title = 'general.breadcrumbs.home' | t
  assign other_templates = 'blog, cart, list-collections, page, search' | split: ', '

  if template.name == 'blog' or template.name == 'page'
    assign item_title = [template.name].title
    assign item_url = [template.name].url
  elsif template.name == 'list-collections'
    assign item_title = 'general.breadcrumbs.collections' | t
    assign item_url = routes.collections_url
  elsif template.name == 'collection' or template.name == 'product'
    assign collections_title = 'general.breadcrumbs.collections' | t
  elsif template.name == 'search'
    assign item_title = 'general.search.title' | t
    assign item_url = routes.search_url
    assign show_structured_data = false
  elsif template.name == 'cart'
    assign item_title = 'cart.general.title' | t
    assign item_url = routes.cart_url
    assign show_structured_data = false
  elsif template.directory == 'customers'
    assign item_title = 'customer.account.title' | t
    assign item_url = routes.account_url
    assign show_structured_data = false
  endif
-%}

{%- if template.name == 'blog' and current_tags -%}
  {%- liquid
    assign current_tags_handles = nil | sort | compact
    for current_tag in current_tags
      assign current_tag_handle = current_tag | handleize | sort
      assign current_tags_handles = current_tags_handles | concat: current_tag_handle
    endfor
    assign current_tags_handles = current_tags_handles
  -%}

  {%- capture blog_tag_url -%}{{ blog.url }}/tagged/{{ current_tags_handles | join: "+" }}{%- endcapture -%}
{%- endif -%}

{%- liquid
  unless divider
    capture divider
      render 'icon-chevron-right'
    endcapture
  endunless

  unless prev_icon
    capture prev_icon
      render 'icon-chevron-left'
    endcapture
  endunless

  unless next_icon
    capture next_icon
      render 'icon-chevron-right'
    endcapture
  endunless
-%}

{%- capture crumbs_structured_data -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ home_title | json }},
          "item": {{ shop.url | append: routes.root_url | json }}
        },

        {%- if template.name == 'collection' and collection.handle -%}
          {%- assign collection_position = 2 -%}
          {%- if show_collection_listing_link -%}
            {
              "@type": "ListItem",
              "position": 2,
              "name": {{ collections_title | json }},
              "item": {{ shop.url | append: routes.collections_url | json }}
            },
            {%- assign collection_position = 3 -%}
          {%- endif -%}
          {
            "@type": "ListItem",
            "position": {{ collection_position }},
            "name": {{ collection.title | json }},
            "item": {{ shop.url | append: collection.url | json }}
          }

        {%- elsif template.name == 'product' -%}
          {%- assign product_position = 2 -%}
          {%- if collection -%}
            {%- if show_collection_listing_link -%}
              {
                "@type": "ListItem",
                "position": 2,
                "name": {{ collections_title | json }},
                "item": {{ shop.url | append: routes.collections_url | json }}
              },
              {%- assign product_position = 3 -%}
            {%- endif -%}
            {
              "@type": "ListItem",
              "position": {{ product_position }},
              "name": {{ collection.title | json }},
              "item": {{ shop.url | append: collection.url | json }}
            },
            {%- if show_collection_listing_link -%}
              {%- assign product_position = 4 -%}
            {%- else -%}
              {%- assign product_position = 3 -%}
            {%- endif -%}
          {%- endif -%}
          {
            "@type": "ListItem",
            "position": {{ product_position }},
            "name": {{ product.title | json }},
            "item": {{ shop.url | append: product.url | json }}
          }

        {%- elsif template.name == 'blog' and current_tags -%}
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ shop.url | append: blog.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ current_tags | join: ", " | json }},
            "item": {{ shop.url | append: blog_tag_url | json }}
          }

        {%- elsif template.name == 'article' -%}
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ shop.url | append: blog.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ article.title | json }},
            "item": {{ shop.url | append: article.url | json }}
          }

        {%- else -%}
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ item_title | json }},
            "item": {{ shop.url | append: item_url | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endcapture -%}

{%- capture crumbs_html -%}
  <nav class="breadcrumbs flex justify-between w-full" aria-label="{{ breadcrumbs_title }}">
    <ol class="breadcrumbs-list flex has-ltr-icon">
      <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
        <a href="{{ routes.root_url }}" itemprop="item"><span itemprop="name">Home</span></a>
        <meta itemprop="position" content="1" />
      </li>

      {%- if template.name == 'collection' and collection.handle -%}
            {% if show_collection_listing_link %}
              <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">     
                <a href="{{ routes.collections_url }}" itemprop="item"><span itemprop="name">{{ 'layout.header.breadcrumbs_collections' | t }}</span></a>
                <meta itemprop="position" content="2" />
              </li>
            {% endif %}
          
            {% comment %}--------collection breadcrumb 1----------{% endcomment %}
            {% if collection.metafields.custom.breadcrumb_1_title != blank %}
              <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">      
                  {{ divider }}
                  <a class='dynmic' href='{{ collection.metafields.custom.breadcrumb_1_link }}' itemprop="item"><span itemprop="name">{{ collection.metafields.custom.breadcrumb_1_title }}</span></a>
                  <meta itemprop="position" content="2" />
              </li>
            {% endif %}
            {% comment %}--------collection breadcrumb 1 END------{% endcomment %}
        
            {% comment %}--------collection breadcrumb 2----------{% endcomment %}
            {% if collection.metafields.custom.breadcrumb_2_title != blank %}
            <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
                  {{ divider }}
                  <a class='dynmic' href='{{ collection.metafields.custom.breadcrumb_2_link }}' itemprop="item"><span itemprop="name">{{ collection.metafields.custom.breadcrumb_2_title }}</span></a>
              {% if collection.metafields.custom.breadcrumb_1_title == blank %}
                  <meta itemprop="position" content="2" />
              {% else %}
                  <meta itemprop="position" content="3" />
              {% endif %}
            </li>
            {% endif %}
            {% comment %}--------collection breadcrumb 2 END------{% endcomment %}
        
            {% comment %}--------collection breadcrumb 3----------{% endcomment %}
            {% if collection.metafields.custom.breadcrumb_3_title != blank %}
            <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
                  {{ divider }}
                  <a class='dynmic' href='{{ collection.metafields.custom.breadcrumb_3_link }}' itemprop="item"><span itemprop="name">{{ collection.metafields.custom.breadcrumb_3_title }}</span></a>
              {% if collection.metafields.custom.breadcrumb_1_title == blank and collection.metafields.custom.breadcrumb_2_title == blank %}
                  <meta itemprop="position" content="2" />
              {% elsif collection.metafields.custom.breadcrumb_1_title == blank and collection.metafields.custom.breadcrumb_2_title != blank %}
                <meta itemprop="position" content="3" />
              {% elsif collection.metafields.custom.breadcrumb_1_title != blank and collection.metafields.custom.breadcrumb_2_title == blank %}
                <meta itemprop="position" content="3" />
              {% else %}
                  <meta itemprop="position" content="4" />
              {% endif %}
            </li>
            {% endif %}
            {% comment %}--------collection breadcrumb 3 END------{% endcomment %} 
        
            <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
              {{ divider }}
              <a class="breadcrumb-active" href="{{ product.url }}" itemprop="item"><span itemprop="name">{{ collection.title }}</span></a>
        
              {% if collection.metafields.custom.breadcrumb_1_title == blank and collection.metafields.custom.breadcrumb_2_title == blank and collection.metafields.custom.breadcrumb_3_title == blank %}
                <meta itemprop="position" content="2" />
        
              {% elsif collection.metafields.custom.breadcrumb_1_title != blank and collection.metafields.custom.breadcrumb_2_title == blank and collection.metafields.custom.breadcrumb_3_title == blank %}
                <meta itemprop="position" content="3" />
        
              {% elsif collection.metafields.custom.breadcrumb_1_title == blank and collection.metafields.custom.breadcrumb_2_title != blank and collection.metafields.custom.breadcrumb_3_title == blank %}
                <meta itemprop="position" content="3" />
        
              {% elsif collection.metafields.custom.breadcrumb_1_title == blank and collection.metafields.custom.breadcrumb_2_title == blank and collection.metafields.custom.breadcrumb_3_title != blank %}
                <meta itemprop="position" content="3" />
        
              {% elsif collection.metafields.custom.breadcrumb_1_title != blank and collection.metafields.custom.breadcrumb_2_title != blank and collection.metafields.custom.breadcrumb_3_title == blank %}
                <meta itemprop="position" content="4" />
              
              {% elsif collection.metafields.custom.breadcrumb_1_title != blank and collection.metafields.custom.breadcrumb_2_title == blank and collection.metafields.custom.breadcrumb_3_title != blank %}
              <meta itemprop="position" content="4" />
        
              {% elsif collection.metafields.custom.breadcrumb_1_title == blank and collection.metafields.custom.breadcrumb_2_title != blank and collection.metafields.custom.breadcrumb_3_title != blank %}
                <meta itemprop="position" content="4" />
        
              {% else %}
                <meta itemprop="position" content="5" />
              {% endif %}
        
        
            </li>
        
          
            {% if current_tags %}
                {% capture tag_url %}{{ collection.url }}/{{ current_tags | join: "+"}}{% endcapture %}
              <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
                {{ divider }}
                <a class="breadcrumb-active" href="{{ tag_url }}" itemprop="item"><span itemprop="name">{{ current_tags | join: " + "}}</span></a>
                {% if show_collection_listing_link %}
                  <meta itemprop="position" content="4" />
                {% else %}
                  <meta itemprop="position" content="3" />
                {% endif %}
              </li>
            {% endif %}

      {%- elsif template.name == 'product' -%}
        {% if collection and show_collection_listing_link %}
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            {{ divider }}7
            <a href="{{ routes.collections_url }}" itemprop="item"><span itemprop="name">{{ 'layout.header.breadcrumbs_collections' | t }}</span></a>
            <meta itemprop="position" content="2" />
          </li>
        {% endif %}
        {% if collection %}
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            {{ divider }}
            <a href="{{ collection.url }}" itemprop="item"><span itemprop="name">{{ collection.title }}</span></a>
            {% if show_collection_listing_link %}
              <meta itemprop="position" content="3" />
            {% else %}
              <meta itemprop="position" content="2" />
            {% endif %}
          </li>
        {% endif %}
    
        {% comment %}--------Product breadcrumb 1 --------{% endcomment %} 
        {% if product.metafields.custom.breadcrumb_1_title != blank %}
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">      
              {{ divider }}
              <a class='dynmic' href='{{ product.metafields.custom.breadcrumb_1_link }}' itemprop="item"><span itemprop="name">{{ product.metafields.custom.breadcrumb_1_title }}</span></a>
              <meta itemprop="position" content="2" />
          </li>
        {% endif %}
        {% comment %}--------Product breadcrumb 1 END-----{% endcomment %} 
    
        {% comment %}--------Product breadcrumb 2---------{% endcomment %} 
        {% if product.metafields.custom.breadcrumb_2_title != blank %}
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
              {{ divider }}
              <a class='dynmic' href='{{ product.metafields.custom.breadcrumb_2_link }}' itemprop="item"><span itemprop="name">{{ product.metafields.custom.breadcrumb_2_title }}</span></a>
          {% if product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title != blank %}
              <meta itemprop="position" content="2" />
          {% else %}
              <meta itemprop="position" content="3" />
          {% endif %}
        </li>
        {% endif %}
        {% comment %}--------Product breadcrumb 2 END-----{% endcomment %} 
    
         {% comment %}-------Product breadcrumb 3---------{% endcomment %}
         {% if product.metafields.custom.breadcrumb_3_title != blank %}
         <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
               {{ divider }}
               <a class='dynmic' href='{{ product.metafields.custom.breadcrumb_3_link }}' itemprop="item"><span itemprop="name">{{ product.metafields.custom.breadcrumb_3_title }}</span></a>
           {% if product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title == blank %}
               <meta itemprop="position" content="2" />
           {% elsif product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title != blank %}
             <meta itemprop="position" content="3" />
           {% elsif product.metafields.custom.breadcrumb_1_title != blank and product.metafields.custom.breadcrumb_2_title == blank %}
             <meta itemprop="position" content="3" />
           {% else %}
               <meta itemprop="position" content="4" />
           {% endif %}
         </li>
         {% endif %}
         {% comment %}------Product breadcrumb 3 END------{% endcomment %} 
    
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          {{ divider }}
          <a class="breadcrumb-active" href="{{ product.url }}" itemprop="item"><span itemprop="name">{{ product.title }}</span></a>
          {% if product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title == blank and product.metafields.custom.breadcrumb_3_title == blank %}
          <meta itemprop="position" content="2" />
        {% elsif product.metafields.custom.breadcrumb_1_title != blank and product.metafields.custom.breadcrumb_2_title == blank and product.metafields.custom.breadcrumb_3_title == blank %}
          <meta itemprop="position" content="3" />
        {% elsif product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title != blank and product.metafields.custom.breadcrumb_3_title == blank %}
          <meta itemprop="position" content="3" />
        {% elsif product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title == blank and product.metafields.custom.breadcrumb_3_title != blank %}
          <meta itemprop="position" content="3" />
        {% elsif product.metafields.custom.breadcrumb_1_title != blank and product.metafields.custom.breadcrumb_2_title != blank and product.metafields.custom.breadcrumb_3_title == blank %}
          <meta itemprop="position" content="4" />   
        {% elsif product.metafields.custom.breadcrumb_1_title != blank and product.metafields.custom.breadcrumb_2_title == blank and product.metafields.custom.breadcrumb_3_title != blank %}
        <meta itemprop="position" content="4" />
        {% elsif product.metafields.custom.breadcrumb_1_title == blank and product.metafields.custom.breadcrumb_2_title != blank and product.metafields.custom.breadcrumb_3_title != blank %}
          <meta itemprop="position" content="4" />
        {% else %}
          <meta itemprop="position" content="5" />
        {% endif %}
        </li>

      {%- elsif template.name == 'blog' and current_tags -%}
        <li class="flex items-center">
          <a class="breadcrumbs-list__link" href="{{ blog.url }}">{{ blog.title | escape }}</a> {{ divider }}
        </li>
        <li class="flex items-center">
          <a class="breadcrumbs-list__link" href="{{ blog_tag_url }}" aria-current="page">{{ current_tags | join: ", " }}</a>

          {%- if show_rss_link -%}
            <a class="breadcrumbs-list__link breadcrumbs-list__link--rss" href="{{ blog.url }}.atom" title="RSS" arial-label="RSS">{% render 'icon-rss' %}</a>
          {%- endif -%}
        </li>

      {%- elsif template.name == 'article' -%}
        <li class="flex items-center">
          <a class="breadcrumbs-list__link" href="{{ blog.url }}">{{ blog.title | escape }}</a> {{ divider }}
        </li>
        <li class="flex items-center">
          <a class="breadcrumbs-list__link" href="{{ article.url }}" aria-current="page">{{ article.title | escape }}</a>
        </li>

      {%- elsif other_templates contains template.name or template.directory == 'customers' -%}
        <li class="flex items-center">
          <a class="breadcrumbs-list__link" href="{{ item_url }}" aria-current="page">{{ item_title | escape }}</a>

          {%- if show_rss_link -%}
            <a class="breadcrumbs-list__link breadcrumbs-list__link--rss" href="{{ blog.url }}.atom" title="RSS" arial-label="RSS">{% render 'icon-rss' %}</a>
          {%- endif -%}
        </li>

      {%- else -%}
        {%- assign show_crumbs = false -%}
      {%- endif -%}
    </ol>

    {%- if show_next_prev and template contains 'product' and collection -%}
      <div class="breadcrumbs-prod-nav flex items-center">
        {%- if collection.previous_product -%}
          <a class="breadcrumbs-prod-nav__link breadcrumbs-prod-nav__link--prev flex items-center" href="{{ collection.previous_product.url }}" title="{{ collection.previous_product.title | escape }}">
            {{ prev_icon }} <span class="breadcrumbs-prod-nav__text">{{ 'products.product.prev_product' | t }}</span>
          </a>
        {%- endif -%}
        {%- if collection.next_product -%}
          <a class="breadcrumbs-prod-nav__link breadcrumbs-prod-nav__link--next flex items-center" href="{{ collection.next_product.url }}" title="{{ collection.next_product.title | escape }}">
            <span class="breadcrumbs-prod-nav__text">{{ 'products.product.next_product' | t }}</span> {{ next_icon }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </nav>
{%- endcapture -%}

{%- if show_crumbs -%}
  {%- if show_structured_data -%}
    {{ crumbs_structured_data }}
  {%- endif -%}
  {{ crumbs_html }}
{%- endif -%}
