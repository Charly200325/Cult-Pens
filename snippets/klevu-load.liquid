                        case "NAME_DESC":
                            selectedText = "Name: Z to A";
                            break;
                        case "NEW_ARRIVAL_DESC":
                            selectedText = "Newest to Oldest";
                            break;
                        case "NEW_ARRIVAL_ASC":
                            selectedText = "Oldest to Newest";
                            break;
                        default:
                            selectedText = "Best Match";
                      }
                      return selectedText;
                  }
                }
              }
