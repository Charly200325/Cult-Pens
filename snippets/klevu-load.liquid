                filter.options.sort(function (a, b) {
                  // Extract numerical parts and convert them to numbers for comparison
                  const numA = a.name.toLowerCase();
                  const numB = b.name.toLowerCase();
                  
                  if (numA < numB) return -1;
                  if (numA > numB) return 1;
                  return 0;
                });
              }
            
            
