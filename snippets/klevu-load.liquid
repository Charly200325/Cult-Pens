              "{{ collection.title }}"{% unless forloop.last %}, {% endunless %}
            {% endfor %}
          ],
          "AddedItemImageURL": "{{ cart.items.last.product.featured_image.src | img_url: 'medium' }}",
          "AddedItemURL": "{{ cart.items.last.product.url }}",
          "AddedItemPrice": {{ cart.items.last.price | money_without_currency }},
          "AddedItemQuantity": {{ cart.items.last.quantity }},
          "ItemNames": [
            {% for item in cart.items %}
              "{{ item.product.title }}"{% unless forloop.last %}, {% endunless %}
            {% endfor %}
          ],
          "CheckoutURL": "{{ checkout.url }}",
          "Items": [
            {% for item in cart.items %}
              {
                "ProductID": "{{ item.product.id }}",
                "SKU": "{{ item.sku }}",
                "ProductName": "{{ item.product.title }}",
                "Quantity": {{ item.quantity }},
                "ItemPrice": {{ item.price | money_without_currency }},
                "RowTotal": {{ item.line_price | money_without_currency }},
                "ProductURL": "{{ item.product.url }}",
                "ImageURL": "{{ item.product.featured_image.src | img_url: 'medium' }}",
                "ProductCategories": [
                  {% for collection in item.product.collections %}
                    "{{ collection.title }}"{% unless forloop.last %}, {% endunless %}
