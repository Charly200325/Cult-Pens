  {% if section.settings.left-id != blank %}
    <style>
      .two-tube-container {
        display: flex;
        flex-direction: row;
        align-items: top;
        justify-content: center;
        padding-top: 10px;
        padding-bottom: 5px;
      }
      @media (max-width: 800px) {
          .two-tube-container {
            flex-direction: column;
        }
        .two-tube-content {
          width: 100% !important;
          height: 200px !important;
        }
      }
      .two-tube-content {
        width: 50%;
        height: 200px;
        text-align: center;
      }
      .two-tube-left {
        margin-left: 64px;
        margin-right: 10px;
      }
      .two-tube-right {
        margin-right: 94px;
        margin-left: 10px;
      }
      .two-tube-left > .metafield-rich_text_field > p {
        margin-right: 20px;
        margin-left: 20px;
      }
      .two-tube-right  > .metafield-rich_text_field > p {
        margin-left: 20px;
        margin-right: 20px;
      }
      h3.two-tube-title {
        font-size: 120%;
      }
      h3.two-tube-title a {
        color: black;
      }
    </style>
    
    <div class="two-tube-container">
      <div class="two-tube-left two-tube-content">
        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/{{ section.settings.left-id }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        <p class="two-tube-left-text">{{ section.settings.left-text }}</p>
      </div>
      <div class="two-tube-right two-tube-content">
        {% if section.settings.right-id != blank %}
          <iframe width="100%" height="100%" src="https://www.youtube.com/embed/{{ section.settings.right-id }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          <p class="two-tube-right-text">{{ section.settings.right-text }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

{% schema %}
  {
    "name": "TwoTube",
    "settings": [
      {
        "type": "text",
        "label": "Left YouTube ID",
        "id": "left-id"
      },
      {
        "type": "richtext",
        "label": "Left text",
        "id": "left-text"
      },
      {
        "type": "text",
        "label": "Right YouTube ID",
        "id": "right-id"
      },
      {
        "type": "richtext",
        "label": "Right text",
        "id": "right-text"
      }
    ],
    "presets": [
      {
        "name": "TwoTube"
      }
    ]
  }
{% endschema %}