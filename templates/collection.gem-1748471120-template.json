{
  "sections": {
    "collection-banner": {
      "type": "main-collection-banner",
      "settings": {
        "show_collection_title": true,
        "show_product_count": false,
        "show_collection_description": true,
        "collection_title_size": "h2",
        "text_width": "wide",
        "text_align": "text-start",
        "text_position": "justify-start items-center",
        "show_image": false,
        "use_product_image": false,
        "collection_image": "1",
        "color_scheme": "default"
      }
    },
    "custom_liquid_fEfMKg": {
      "type": "custom-liquid",
      "disabled": true,
      "custom_css": [
        ".subcollection {display: flex; flex-flow: row wrap; max-width: 100%;}",
        ".subcollectionitems {width: 23.2%; margin-right: 20px; margin-bottom: 20px;}",
        ".subcollectionitems p {font-size: 20px; margin: 20px 10px 0; text-align: center;}",
        ".subcollectionitems p {color: #999999;}"
      ],
      "settings": {
        "custom_liquid": "{%- if collection.metafields.custom.subcollection.value != blank -%}\n<div class=\"subcollection page-width\">\n    {% assign subcollection =  collection.metafields.custom.subcollection.value %}\n  {% for subcollection in collection.metafields.custom.subcollection.value %}\n  <div class=\"subcollectionitems\">\n      <a href=\"{{ subcollection.url }}\">\n        <img src=\"{{ subcollection.featured_image | img_url: '324x' }}\">\n        <div>\n          <p>{{ subcollection.title }}<\/p>\n        <\/div>\n       <\/a>\n      <\/div>\n\n\n   {%  endfor %}\n<\/div>\n\n{% else %}\n {%- endif -%}",
        "section_height": "default",
        "full_width": false,
        "dividers": "none",
        "prevent_animation": false
      }
    },
    "subcollections_rACYz6": {
      "type": "subcollections",
      "name": "Subcollections",
      "settings": {
        "subcollections": "{{ collection.metafields.custom.subcollection.value }}"
      }
    },
    "klevu_collection_theme_igy76X": {
      "type": "klevu-collection-theme",
      "settings": {}
    },
    "collection-products": {
      "type": "main-collection-products",
      "blocks": {
        "image_promotion_kqxbRA": {
          "type": "image-promotion",
          "disabled": true,
          "settings": {
            "position": 4,
            "view": "grid_list",
            "hide_on_filter": true,
            "min_height": 150,
            "link_url": "",
            "content": "<h6>Promotion text<\/h6>",
            "text_type_scale": "1em",
            "text_width": 400,
            "text_alignment": "justify-center items-center text-center",
            "button_label": "Optional Button",
            "button_style": "link",
            "text_color": "#ffffff",
            "tint_color": "#000000",
            "tint_opacity": 20
          }
        }
      },
      "block_order": [
        "image_promotion_kqxbRA"
      ],
      "disabled": true,
      "settings": {
        "products_per_page": 48,
        "card_size_mobile": "small",
        "card_size": "small",
        "show_layout_toggle": true,
        "enable_filtering": true,
        "filters_open_lg": true,
        "stick_on_scroll": true,
        "show_filter_counts": true,
        "expand_filters": true,
        "max_filter_options": 8,
        "enable_sorting": true,
        "show_feat_sort_opt": true,
        "sort_first": true
      }
    },
    "rich_text_rp9tkt": {
      "type": "rich-text",
      "blocks": {
        "heading_YPYGqf": {
          "type": "heading",
          "disabled": true,
          "settings": {
            "heading": "{{ collection.title }} FAQ",
            "heading_size": "h2",
            "heading_h1": false
          }
        },
        "text_yRCbNP": {
          "type": "text",
          "settings": {
            "text": "{{ collection.metafields.custom.collection_faq_s | metafield_tag }}",
            "enlarge_text": false
          }
        }
      },
      "block_order": [
        "heading_YPYGqf",
        "text_yRCbNP"
      ],
      "settings": {
        "text_position": "justify-center",
        "text_align": "text-center",
        "mob_center_text": true,
        "color_scheme": "none",
        "full_width": true,
        "prevent_animation": false
      }
    }
  },
  "order": [
    "collection-banner",
    "custom_liquid_fEfMKg",
    "subcollections_rACYz6",
    "klevu_collection_theme_igy76X",
    "collection-products",
    "rich_text_rp9tkt"
  ]
}
