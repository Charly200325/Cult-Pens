<meta name="robots" content="noindex">

<div class="site-map">
  <div class="section-header text-center" style="margin-top:30px;">
    <h1>{{ page.title }}</h1>
  </div>
  <div class="rte">
    {%- comment -%} Start of HTML SiteMap code {%- endcomment -%}
    <div class="sitemapListWrapper row">
      <div class="sitemapList">
        <h2>Collections</h2>
        <ul>
          {% for c in collections %}
            <li>
              <a href="{{ c.url }}">{{ c.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="sitemapList">
        <h2>Products</h2>
        <ul>
          {% paginate collections.all.products by 1000 %}
            {% for product in collections.all.products %}
              <li>
                <a href="{{ product.url }}">{{ product.title }}</a>
              </li>
            {% endfor %}
          {% endpaginate %}
        </ul>
      </div>
      <div class="sitemapList">
        <h2>Pages</h2>
        <ul>
          {% for p in pages %}
            <li>
              <a href="{{ p.url }}">{{ p.title | remove: 'Info ' }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="sitemapList">
        <h2>Blog Posts</h2>
        <ul>
          {% assign blog_handles = 'news' | split: ',' %}

          {% for handle in blog_handles %}
            {% for article in blogs[handle].articles %}
              <li>
                <a href="{{ article.url }}">{{ article.title }}</a>
              </li>
            {% endfor %}
          {% endfor %}
        </ul>
      </div>
    </div>
    {%- comment -%}
      End of HTML SiteMap code
    {%- endcomment -%}
  </div>
</div>
